# ============================================================
# DID System – Environment Variables Example
# Sao chép file này thành .env và điền thông tin thực tế
# ============================================================

# === Địa chỉ Smart Contract (cập nhật sau mỗi lần deploy) ===
DID_REGISTRY_ADDRESS=0x...
CREDENTIAL_REGISTRY_ADDRESS=0x...
IDENTITY_VERIFIER_ADDRESS=0x...

# === Cấu hình mạng ===
NETWORK_URL=http://127.0.0.1:7545
CHAIN_ID=1337

# === Tài khoản Ganache ===
# Lấy private key từ Ganache UI: click biểu tượng chìa khóa
PRIVATE_KEY_DEPLOYER=0x3f8a8fbb57a4e9be12c4b461e3d604d7e4bfde4d483cdff6fb3659ce293ac435
PRIVATE_KEY_ISSUER=0x686f1268a22265ea495b6c3b01924f611b60eceb2188c06850152d03029cfb49    # Tài khoản #1 – Issuer (Trường/Khoa)
PRIVATE_KEY_HOLDER=0x76bbddfc7a86679fc6653e21bf0241a1e4950097e689e3ae9e1810a45d6de7c8     # Tài khoản #2 – Holder (Sinh viên)
PRIVATE_KEY_VERIFIER=0x2b5baa9a728510da115caae6a7072dae350ea520171fdb2f93843b8d10d30242    # Tài khoản #3 – Verifier (Nhà tuyển dụng)
